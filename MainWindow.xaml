<Window x:Class="PptNotesHandoutMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PptNotesHandoutMaker"
        xmlns:core="clr-namespace:PptNotesHandoutMaker.Core"
        mc:Ignorable="d"
        Title="Instructor Guide Generator"
        Height="760"
        Width="800"
        MinHeight="760"
        MinWidth="800">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="18"
                   FontWeight="Bold"
                   Text="Andy's Handy Dandy Instructor Guide Maker" />

        <Grid Grid.Row="1" Margin="0,30,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="81"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
               Text="Class name:"
               VerticalAlignment="Center"
               HorizontalAlignment="Right"
               Margin="0,0,10,0"/>

            <TextBox Grid.Column="1"
                 x:Name="ClassNameBox"
                 Height="26"
                 VerticalContentAlignment="Center"
                 TextChanged="AnyInputChanged"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="81"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="28"/>
                <ColumnDefinition Width="45"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
       Text="Rev:"
       VerticalAlignment="Center"
       HorizontalAlignment="Right"
       Margin="0,0,10,0"/>

            <TextBox Grid.Column="1"
         x:Name="RevisionBox"
         Width="40"
         Height="26"
         MaxLength="2"
         VerticalContentAlignment="Center"
         HorizontalContentAlignment="Center"
         HorizontalAlignment="Left"
         TextChanged="AnyInputChanged"
         PreviewTextInput="RevisionBox_PreviewTextInput"
         DataObject.Pasting="RevisionBox_Pasting"/>

            <TextBlock Grid.Column="5"
               Text="Date:"
               VerticalAlignment="Center"
               HorizontalAlignment="Right"
               Margin="0,0,10,0"/>

            <TextBox Grid.Column="6"
                 x:Name="DateBox"
                 Width="90"
                 Height="26"
                 MaxLength="7"
                 VerticalContentAlignment="Center"
                 HorizontalContentAlignment="Center"
                 HorizontalAlignment="Left"
                 Text="MM/YYYY"
                 Foreground="Gray"
                 TextChanged="AnyInputChanged"
                 PreviewTextInput="DateBox_PreviewTextInput"
                 PreviewKeyDown="DateBox_PreviewKeyDown"
                 GotKeyboardFocus="DateBox_GotKeyboardFocus"
                 DataObject.Pasting="DateBox_Pasting"/>

            <CheckBox Grid.Column="8"
              x:Name="UseCurrentDateCheckBox"
              Content="Use current date"
              VerticalAlignment="Center"
              Margin="0,0,0,0"
              IsChecked="True"
              Checked="UseCurrentDateCheckBox_Changed"
              Unchecked="UseCurrentDateCheckBox_Changed"/>  
        </Grid>

        <GroupBox Grid.Row="3"
                  Margin="0,12,0,0"
                  Padding="12"
                  Height="260"
                  VerticalAlignment="Top">

            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="PowerPoint file(s):" />
                    <TextBlock x:Name="PptCountText"
                               Margin="6,0,0,0"
                               Foreground="Gray"
                               Visibility="Collapsed"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </GroupBox.Header>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,8">
                    <Button x:Name="AddPptBtn"
                            Content="Add PPT"
                            Width="80"
                            Height="26"
                            Margin="0,0,8,0"
                            Click="BrowsePpt_Click" />

                    <Button x:Name="ClearBatchBtn"
                            Content="Clear All"
                            Width="80"
                            Height="26"
                            Click="ClearBatch_Click" />
                </StackPanel>

                <Border Grid.Row="1"
                        x:Name="DropZoneBorder"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="#FAFAFA"
                        Padding="8"
                        AllowDrop="True"
                        PreviewDragOver="Window_PreviewDragOver"
                        DragLeave="Window_DragLeave"
                        Drop="Window_Drop">
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="BatchItemsControl"
                                          ItemsSource="{Binding SelectedPpts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="1"
                                                Margin="0,0,0,10"
                                                Padding="8"
                                                CornerRadius="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="LightGray" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UsedFilenameFallback}" Value="True">
                                                            <Setter Property="BorderBrush" Value="DarkOrange" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding DisplayFileName}"
                                                               ToolTip="{Binding PptPath}"
                                                               FontWeight="Bold"
                                                               Margin="0,0,8,2"
                                                               VerticalAlignment="Center" />

                                                    <Button Grid.Column="1"
                                                            Content="X"
                                                            Width="26"
                                                            Height="26"
                                                            Tag="{Binding}"
                                                            ToolTip="Remove this PowerPoint from the batch"
                                                            Click="RemoveBatchItem_Click" />
                                                </Grid>

                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,2,0,2">
                                                    <TextBlock FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               Text="PDF Title:" />

                                                    <TextBlock Margin="6,0,0,0"
                                                               Foreground="DarkOrange"
                                                               VerticalAlignment="Center"
                                                               Text="Used file name as fallback - review title">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding UsedFilenameFallback}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <TextBlock Margin="6,0,0,0"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding UsedFilenameFallback}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>

                                                        <Hyperlink Tag="{Binding}"
                                                                   Click="RetryTitleRead_Link_Click">
                                                            <Run Text="[Retry]" />
                                                        </Hyperlink>
                                                    </TextBlock>
                                                </StackPanel>

                                                <TextBox Text="{Binding PdfTitle, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock x:Name="DropHintText"
                                   Text="Drag and drop PowerPoint files here"
                                   Foreground="Gray"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Opacity="0.75"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Border>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Output folder:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <TextBox Grid.Column="1"
                     x:Name="OutPathBox"
                     Height="26"
                     VerticalContentAlignment="Center"
                     IsReadOnly="True"
                     Margin="0,0,10,0"/>

            <Button Grid.Column="2"
                    Width="110"
                    Height="26"
                    Click="BrowseOut_Click">
                Browse…
            </Button>
        </Grid>

        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="GenerateBtn"
                    Content="Generate"
                    Width="200"
                    Height="30"
                    Click="Generate_Click"
                    Grid.Column="1"
                    HorizontalAlignment="Center"/>

            <CheckBox x:Name="AlwaysUseTempCopyCheckBox"
                      Content="Always use local temp copy"
                      Margin="10,5,0,0"
                      VerticalAlignment="Center"
                      Checked="AnyOptionChanged"
                      Unchecked="AnyOptionChanged"
                      Grid.Column="2"
                      HorizontalAlignment="Left"/>
        </Grid>

        <TextBlock Grid.Row="6"
                   x:Name="StatusLabel"
                   Margin="0,16,0,4"
                   Text="Status:" />

        <TextBox Grid.Row="7"
                 x:Name="StatusBox"
                 Margin="0,0,0,0"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap" />
    </Grid>
</Window>